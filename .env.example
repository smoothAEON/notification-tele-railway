# Required provider credentials
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice

# Required Telegram runtime settings
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Required MCP HTTP bearer token
MCP_HTTP_API_KEY=

# Railway injects PORT automatically. Local fallback:
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8000
MCP_HTTP_PATH=/mcp

# Railway volume default is /data/alerts.db.
# For local development, use data/alerts.db.
ALERT_DB_PATH=data/alerts.db

# Deprecated/diagnostic only. Background monitoring is driven by active alerts.
STREAM_INSTRUMENTS=

LOG_LEVEL=INFO
LOG_JSON=false
